{
    "name": "kozmonos/laravel-vertex-ai",
    "description": "Laravel bridge for kozmonos/vertex-ai",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "vertex-ai",
        "google-cloud",
        "gemini",
        "ai"
    ],
    "authors": [
        {
            "name": "Kozmonos",
            "homepage": "https://github.com/kozmonos"
        }
    ],
    "homepage": "https://github.com/kozmonos/laravel-vertex-ai",
    "support": {
        "issues": "https://github.com/kozmonos/laravel-vertex-ai/issues",
        "source": "https://github.com/kozmonos/laravel-vertex-ai"
    },
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "kozmonos/vertex-ai": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Kozmonos\\LaravelVertexAi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kozmonos\\LaravelVertexAi\\Tests\\": "tests/"
        },
        "files": [
            "tests/Support/helpers.php"
        ]
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse -c phpstan.neon",
        "audit": "composer audit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kozmonos\\LaravelVertexAi\\LaravelVertexAiServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
